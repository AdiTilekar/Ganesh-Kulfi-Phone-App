# Environment Variables for Ganesh Kulfi Backend
# Copy this file to .env and fill in your actual values
# DO NOT commit .env with real secrets — only .env.example is tracked.

# Database Configuration
POSTGRES_DB=ganeshkulfi_db
POSTGRES_USER=ganeshkulfi_user
POSTGRES_PASSWORD=          # REQUIRED — choose a strong password
DB_URL=jdbc:postgresql://localhost:5432/ganeshkulfi_db
DB_USER=ganeshkulfi_user
DB_PASSWORD=                # REQUIRED — same as POSTGRES_PASSWORD
DB_POOL_SIZE=10

# JWT Configuration
JWT_SECRET=                 # REQUIRED — minimum 32 random characters
JWT_ISSUER=ganeshkulfi
JWT_AUDIENCE=ganeshkulfi-app

# CORS (comma-separated origins, leave blank for anyHost in dev)
CORS_ALLOWED_ORIGINS=

# Application Configuration
APP_PORT=8080

# Storage Configuration
UPLOADS_DIR=uploads
